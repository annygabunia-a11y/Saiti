rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == userId && isValidId(userId);
      allow update: if isSignedIn() && request.auth.uid == userId && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'avatarUrl', 'email', 'balance']);
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isSignedIn() && incoming().sellerId == request.auth.uid && isValidId(productId);
      allow update: if isSignedIn() && existing().sellerId == request.auth.uid;
      allow delete: if isSignedIn() && existing().sellerId == request.auth.uid;
    }

    match /transactions/{transactionId} {
      allow read: if isSignedIn() && existing().userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidId(transactionId);
    }
  }
}
